{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact_contract_v1.schema.json",
  "title": "Artifact Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_contract_version",
    "artifact_kind",
    "run",
    "telemetry"
  ],
  "properties": {
    "artifact_contract_version": {
      "type": "string",
      "const": "1.0"
    },
    "artifact_kind": {
      "type": "string",
      "enum": [
        "grounded_reasoner_train",
        "manifold_eval"
      ]
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "pipeline",
        "generated_utc"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "pipeline": {
          "type": "string",
          "enum": [
            "train_grounded_reasoner",
            "eval_manifold"
          ]
        },
        "generated_utc": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_1_topology",
        "system_2_geometry",
        "logical_accuracy"
      ],
      "properties": {
        "system_1_topology": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "arity_violation_rate",
            "surgery_trigger_count",
            "variable_token_distribution"
          ],
          "properties": {
            "arity_violation_rate": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "surgery_trigger_count": {
              "type": "integer",
              "minimum": 0
            },
            "variable_token_distribution": {
              "type": "array",
              "minItems": 1995,
              "maxItems": 1995,
              "items": {
                "type": "number",
                "minimum": 0.0
              }
            }
          }
        },
        "system_2_geometry": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ce_loss_final",
            "cross_attention_gain"
          ],
          "properties": {
            "ce_loss_final": {
              "type": "number",
              "minimum": 0.0
            },
            "cross_attention_gain": {
              "type": "number"
            }
          }
        },
        "logical_accuracy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "value"
          ],
          "properties": {
            "value": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            }
          }
        }
      }
    }
  }
}
