__pycache__/
*.pyc
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local secret/config material
.env
config/
!config/*.example

# Experiment and model artifacts
artifacts/
runs/
src/runs/
*.safetensors
*.pt
*.bin
*.ckpt
*.gguf

# Local scratch dirs created by pytest on this machine
cachepytest/
pytest-cache-files-*/
src/pytest-cache-files-*/
src/.pytest_tmp/
src/.tmp_pytest/
src/pytest-cache-files-*/

# Prevent top-level output clutter from reappearing
RESULTS_*/
ROOT_*/
REPORTS_RELEVANT/
